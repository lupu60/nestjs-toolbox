{
  "name": "@nest-toolbox/open-api-spec-to-ts",
  "description": "nestjs toolbox",
  "version": "1.8.2",
  "author": "getlarge <ed@getlarge.eu>",
  "homepage": "https://github.com/lupu60/nestjs-toolbox/tree/master/packages/open-api-spec-to-ts#readme",
  "license": "MIT",
  "keywords": [
    "nestjs",
    "toolbox",
    "open-api"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupu60/nestjs-toolbox.git"
  },
  "bugs": {
    "url": "https://github.com/lupu60/nestjs-toolbox/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "publicConfig": {
    "access": "public"
  },
  "main": "dist/index",
  "types": "dist/index",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18 <=22",
    "npm": "<=11"
  },
  "scripts": {
    "build": "npm run clean && npm run compile",
    "clean": "rimraf -rf ./dist",
    "cleanup": "rimraf -rf dist coverage ",
    "compile": "tsc -p tsconfig.build.json",
    "lint": "biome check src",
    "test": "vitest run --config ../../vitest.config.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "chalk": "^4.1.0",
    "json-schema-to-typescript": "^15.0.4",
    "lodash": "4.18.1",
    "rimraf": "~6.1.1",
    "role-acl": "3.2.2",
    "ts-node": "10.9.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/node": "25.9.1",
    "typescript": "5.9.3"
  },
  "gitHead": "737971da7af87f7b32335ce5cfe8679704ac219d"
}
